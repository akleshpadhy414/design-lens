# ── Supabase (Auth + DB) ─────────────────────────────────────────────
# Create a free project at supabase.com, then Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...          # public; server only reads to pass to client build
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...  # SECRET — server-only; never commit or expose to client

# AES-256-GCM master key for encrypting user API keys at rest.
# Generate with: openssl rand -base64 32
MASTER_KEY=replace-me-32-bytes-base64

# ── Client (Vite exposes only VITE_-prefixed env at build time) ──────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
